# For LOCAL Streamlit runs you can use .env instead — this file is mainly a
# reference for what to paste into your hosting provider's "Secrets" box.
#
# Copy to ".streamlit/secrets.toml" (git-ignored) if you want to use it locally.
GEMINI_API_KEY = "your-key-here"

